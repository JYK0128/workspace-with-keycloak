{
  "realm": "master",
  "enabled": true,
  "roles": {
    "realm": [
      {
        "name": "viewer",
        "description": "read-only access"
      },
      {
        "name": "editor",
        "description": "read/write access"
      },
      {
        "name": "auditor",
        "description": "audit access"
      }
    ]
  },
  "clients": [
    {
      "clientId": "react-admin",
      "name": "react-admin",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ]
}
