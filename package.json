{
  "name": "workspace-with-keycloak",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.4.2",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "dev:web": "turbo run dev --filter=@apps/web",
    "build:web": "turbo run build --filter=@apps/web",
    "preview:web": "npm run preview -w apps/web",
    "typecheck:web": "turbo run typecheck --filter=@apps/web",
    "dev:bff": "turbo run dev --filter=@apps/bff",
    "typecheck:bff": "turbo run typecheck --filter=@apps/bff"
  },
  "devDependencies": {
    "turbo": "^2.0.12"
  }
}
